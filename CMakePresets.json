{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": ["./ConanPresets.json"],
  "configurePresets": [
    {
        "name": "release-test",
        "displayName": "Release Test Configuration",
        "inherits": "conan-release",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Release",
          "BUILD_TESTS": "ON",
          "SYSTEM_INSTALL": "OFF",
          "ASAN": "OFF",
          "SVS": "OFF",
          "CLI": "ON"
        }
    },
    {
        "name": "debug-shared",
        "displayName": "Debug Shared Configuration",
        "inherits": "conan-debug",
        "cacheVariables": {
          "BUILD_SHARED_LIBS": "ON",
          "CMAKE_BUILD_TYPE": "Debug",
          "BUILD_TESTS": "ON",
          "SYSTEM_INSTALL": "OFF",
          "ASAN": "OFF",
          "SVS": "OFF",
          "CLI": "ON"
        }
    },
    {
        "name": "debug-test",
        "displayName": "Debug Test Configuration",
        "inherits": "conan-debug",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "BUILD_TESTS": "ON",
          "SYSTEM_INSTALL": "OFF",
          "ASAN": "OFF",
          "SVS": "OFF",
          "CLI": "ON"
        }
    },
    {
        "name": "debug-test-asan",
        "displayName": "Debug Test with ASAN",
        "inherits": "conan-debug",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "BUILD_TESTS": "ON",
          "SYSTEM_INSTALL": "OFF",
          "ASAN": "ON",
          "SVS": "OFF",
          "CLI": "ON"
        }
    }
  ],
  "buildPresets": [
    { 
        "name": "debug-shared",
        "displayName": "Build Debug Shared",
        "configurePreset": "debug-shared",
        "configuration": "debug",
        "inherits": "conan-debug"
    },
    { 
        "name": "debug-test",
        "displayName": "Build Debug Test",
        "configurePreset": "debug-test",
        "configuration": "debug",
        "inherits": "conan-debug"
    },
    { 
        "name": "debug-test-asan",
        "displayName": "Build Debug Test with ASAN",
        "configurePreset": "debug-test-asan",
        "configuration": "debug",
        "inherits": "conan-debug"
    },
    { 
        "name": "release-test",
        "displayName": "Build Release Test",
        "configurePreset": "release-test",
        "configuration": "release",
        "inherits": "conan-release"
    }
  ]
}

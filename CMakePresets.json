{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "include": [
        "./ConanPresets.json"
    ],
    "configurePresets": [
        {
            "name": "Debug-shared",
            "displayName": "Debug Shared Configuration",
            "inherits": "conan-debug",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON",
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_PERFORMANCE_TESTS": "OFF",
                "SWIG": "OFF",
                "ASAN": "OFF",
                "SVS": "OFF",
                "CLI": "ON"
            }
        },
        {
            "name": "Release-shared",
            "displayName": "Release Shared Configuration",
            "inherits": "conan-release",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON",
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_PERFORMANCE_TESTS": "OFF",
                "SWIG": "OFF",
                "ASAN": "OFF",
                "SVS": "OFF",
                "CLI": "ON"
            }
        },
        {
            "name": "Release-static",
            "displayName": "Release Static Configuration",
            "inherits": "conan-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_PERFORMANCE_TESTS": "OFF",
                "SWIG": "OFF",
                "ASAN": "OFF",
                "SVS": "OFF",
                "CLI": "ON"
            }
        },
        {
            "name": "Debug-static",
            "displayName": "Debug Static Configuration",
            "inherits": "conan-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_PERFORMANCE_TESTS": "OFF",
                "SWIG": "OFF",
                "ASAN": "OFF",
                "SVS": "OFF",
                "CLI": "ON"
            }
        },
        {
            "name": "Debug-swig",
            "displayName": "Debug with SWIG bindings",
            "inherits": "conan-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SWIG": "ON",
                "SVS": "OFF",
                "CLI": "ON",
                "BUILD_TESTS": "ON",
                "TEST_CI_ENABLED": "OFF",
                "BUILD_PERFORMANCE_TESTS": "OFF"
            }
        },
        {
            "name": "Debug-test-asan",
            "displayName": "Debug Test with ASAN",
            "inherits": "conan-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_PERFORMANCE_TESTS": "OFF",
                "SWIG": "OFF",
                "ASAN": "ON",
                "SVS": "OFF",
                "CLI": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug-shared",
            "displayName": "Build Debug Shared",
            "configurePreset": "Debug-shared",
            "configuration": "debug",
            "inherits": "conan-debug"
        },
        {
            "name": "Release-shared",
            "displayName": "Build Release Shared",
            "configurePreset": "Release-shared",
            "configuration": "release",
            "inherits": "conan-release"
        },
        {
            "name": "Debug-static",
            "displayName": "Build Debug Static",
            "configurePreset": "Debug-static",
            "configuration": "debug",
            "inherits": "conan-debug"
        },
        {
            "name": "Debug-test-asan",
            "displayName": "Build Debug Test with ASAN",
            "configurePreset": "Debug-test-asan",
            "configuration": "debug",
            "inherits": "conan-debug"
        },
        {
            "name": "Release-static",
            "displayName": "Build Release Static",
            "configurePreset": "Release-static",
            "configuration": "release",
            "inherits": "conan-release"
        },
        {
            "name": "Debug-swig",
            "displayName": "Build Debug with SWIG bindings",
            "configurePreset": "Debug-swig",
            "configuration": "debug",
            "inherits": "conan-debug"
        }
    ],
    "testPresets": [
        {
            "name": "Debug-static",
            "displayName": "Test Debug Static",
            "configurePreset": "Debug-static",
            "inherits": "conan-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "Debug-test-asan",
            "displayName": "Test Debug ASAN",
            "configurePreset": "Debug-test-asan",
            "inherits": "conan-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "Debug-shared",
            "displayName": "Test Debug Shared",
            "configurePreset": "Debug-shared",
            "inherits": "conan-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "Release-static",
            "displayName": "Test Release Static",
            "configurePreset": "Release-static",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "Release-shared",
            "displayName": "Test Release Shared",
            "configurePreset": "Release-shared",
            "output": {
                "outputOnFailure": true
            }
        }
    ],
    "packagePresets": [
        {
            "name": "Release-static",
            "displayName": "Package Release Static",
            "configurePreset": "Release-static",
            "packageDirectory": "package-static/"
        },
        {
            "name": "Release-shared",
            "displayName": "Package Release Shared",
            "configurePreset": "Release-shared",
            "packageDirectory": "package-shared/"
        }
    ],
    "workflowPresets": [
        {
            "name": "Debug-static",
            "displayName": "Debug Static",
            "steps": [
                {
                    "type": "configure",
                    "name": "Debug-static"
                },
                {
                    "type": "build",
                    "name": "Debug-static"
                },
                {
                    "type": "test",
                    "name": "Debug-static"
                }
            ]
        },
        {
            "name": "Debug-test-asan",
            "displayName": "Debug Test with ASAN",
            "steps": [
                {
                    "type": "configure",
                    "name": "Debug-test-asan"
                },
                {
                    "type": "build",
                    "name": "Debug-test-asan"
                },
                {
                    "type": "test",
                    "name": "Debug-test-asan"
                }
            ]
        },
        {
            "name": "Release-static",
            "displayName": "Release Static",
            "steps": [
                {
                    "type": "configure",
                    "name": "Release-static"
                },
                {
                    "type": "build",
                    "name": "Release-static"
                },
                {
                    "type": "test",
                    "name": "Release-static"
                }
            ]
        }
    ]
}

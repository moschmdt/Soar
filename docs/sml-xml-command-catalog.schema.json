{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://soar.eecs.umich.edu/schema/sml-xml-command-catalog.schema.json",
    "title": "Soar SML XML Command Catalog",
    "description": "Machine-readable catalog of client->kernel SML XML command names and known parameter expectations.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "sourceOfTruth",
        "commands",
        "declaredButNotMapped"
    ],
    "properties": {
        "schemaVersion": {
            "type": "string"
        },
        "sourceOfTruth": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "buildCommandMapFile",
                "handlerFile",
                "namesFile"
            ],
            "properties": {
                "buildCommandMapFile": {
                    "type": "string"
                },
                "handlerFile": {
                    "type": "string"
                },
                "namesFile": {
                    "type": "string"
                }
            }
        },
        "commands": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/command"
            }
        },
        "declaredButNotMapped": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "$defs": {
        "command": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "handler",
                "agentContext",
                "arguments",
                "commandAttributes",
                "responseShape",
                "notes"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "handler": {
                    "type": "string"
                },
                "agentContext": {
                    "type": "string",
                    "enum": [
                        "required",
                        "optional",
                        "none"
                    ]
                },
                "arguments": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/argument"
                    }
                },
                "commandAttributes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/commandAttribute"
                    }
                },
                "responseShape": {
                    "type": "string",
                    "enum": [
                        "raw-result",
                        "structured-result",
                        "mixed",
                        "none",
                        "implementation-defined"
                    ]
                },
                "notes": {
                    "type": "string"
                }
            }
        },
        "argument": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "param",
                "required",
                "type",
                "notes"
            ],
            "properties": {
                "param": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "string",
                        "int",
                        "bool",
                        "xml-subtree",
                        "unknown"
                    ]
                },
                "notes": {
                    "type": "string"
                }
            }
        },
        "commandAttribute": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "required",
                "allowedValues",
                "notes"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "allowedValues": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "notes": {
                    "type": "string"
                }
            }
        }
    }
}